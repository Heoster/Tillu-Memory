# Copy this to .env for local dev (vercel dev reads it automatically).
# In production, set these in the Vercel dashboard → Project → Settings → Environment Variables.

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Upstash Redis ───────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ─── Groq ────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ─── HuggingFace (embeddings) ─────────────────────────────────────────────────
# Free token at: https://huggingface.co/settings/tokens
# Used for: sentence-transformers/all-MiniLM-L6-v2 (384 dims)
HUGGINGFACE_API_KEY=hf_your_token_here

# ─── Memory Config (optional — defaults shown) ───────────────────────────────
WORKING_MEMORY_TTL=1800
STATE_TTL=3600
MAX_PINNED_MEMORIES=50
MAX_WORKING_MESSAGES=50
MAX_SEMANTIC_RESULTS=10
MEMORY_DECAY_DAYS=90
