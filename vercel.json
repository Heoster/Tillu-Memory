{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/memory.ts": { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/memory/:path*", "destination": "/api/memory" },
    { "source": "/health",        "destination": "/api/health" },
    { "source": "/docs",          "destination": "/api/docs" },
    { "source": "/",              "destination": "/api/index" }
  ]
}
